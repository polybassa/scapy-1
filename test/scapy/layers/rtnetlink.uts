with mock.patch("socket.socket", return_value=mock_sock):
    ips = _get_ips()
    assert ips == {}


############
############

+ RTNetlink _get_if_list

= _get_if_list returns interface info indexed by ifindex
~ mock

from scapy.arch.linux.rtnetlink import (
    rtmsghdr, ifinfomsg, ifinfomsg_rtattr, ifaddrmsg, ifaddrmsg_rtattr,
    nlmsgerr, _get_if_list
)
from unittest import mock
import socket

# Build the link response (sent first by _get_if_list -> _sr1_rtrequest for RTM_GETLINK)
lo = rtmsghdr(
    nlmsg_type="RTM_NEWLINK", nlmsg_flags="NLM_F_MULTI", nlmsg_seq=1, nlmsg_pid=100,
) / ifinfomsg(
    ifi_family=0, ifi_type=772, ifi_index=1,
    ifi_flags="UP+LOOPBACK+RUNNING",
    data=[
        ifinfomsg_rtattr(rta_type="IFLA_ADDRESS", rta_data="00:00:00:00:00:00"),
        ifinfomsg_rtattr(rta_type="IFLA_IFNAME", rta_data=b"lo\x00"),
    ],
)
eth0 = rtmsghdr(
    nlmsg_type="RTM_NEWLINK", nlmsg_flags="NLM_F_MULTI", nlmsg_seq=1, nlmsg_pid=100,
) / ifinfomsg(
    ifi_family=0, ifi_type=1, ifi_index=2,
    ifi_flags="UP+BROADCAST+RUNNING+MULTICAST",
    data=[
        ifinfomsg_rtattr(rta_type="IFLA_ADDRESS", rta_data="de:ad:be:ef:ca:fe"),
        ifinfomsg_rtattr(rta_type="IFLA_IFNAME", rta_data=b"eth0\x00"),
    ],
)
done = rtmsghdr(
    nlmsg_type="NLMSG_DONE", nlmsg_flags=0, nlmsg_seq=1, nlmsg_pid=100,
) / nlmsgerr(status=0, data=[])
link_data = bytes(lo) + bytes(eth0) + bytes(done)

# Build the addr response (sent by _get_ips inside _get_if_list)
lo_addr = rtmsghdr(
    nlmsg_type="RTM_NEWADDR", nlmsg_flags="NLM_F_MULTI", nlmsg_seq=1, nlmsg_pid=100,
) / ifaddrmsg(
    ifa_family=socket.AF_INET, ifa_prefixlen=8, ifa_flags=0x80, ifa_scope=254, ifa_index=1,
    data=[
        ifaddrmsg_rtattr(rta_type="IFA_ADDRESS", rta_data="127.0.0.1"),
        ifaddrmsg_rtattr(rta_type="IFA_LOCAL", rta_data="127.0.0.1"),
    ],
)
eth0_addr = rtmsghdr(
    nlmsg_type="RTM_NEWADDR", nlmsg_flags="NLM_F_MULTI", nlmsg_seq=1, nlmsg_pid=100,
) / ifaddrmsg(
    ifa_family=socket.AF_INET, ifa_prefixlen=24, ifa_flags=0x80, ifa_scope=0, ifa_index=2,
    data=[
        ifaddrmsg_rtattr(rta_type="IFA_ADDRESS", rta_data="192.168.1.2"),
        ifaddrmsg_rtattr(rta_type="IFA_LOCAL", rta_data="192.168.1.2"),
        ifaddrmsg_rtattr(rta_type="IFA_LABEL", rta_data=b"eth0\x00"),
    ],
)
addr_data = bytes(lo_addr) + bytes(eth0_addr) + bytes(done)

# _get_if_list: socket 1 -> link_data, socket 2 -> addr_data
_socket_responses = iter([link_data, addr_data])
def _mock_socket(*args, **kwargs):
    data = next(_socket_responses)
    s = mock.MagicMock()
    s.recv.return_value = data
    return s

with mock.patch("socket.socket", side_effect=_mock_socket):
    ifaces = _get_if_list()

assert 1 in ifaces
assert 2 in ifaces
assert ifaces[1]["name"] == "lo"
assert ifaces[1]["mac"] == "00:00:00:00:00:00"
assert ifaces[1]["type"] == 772
assert ifaces[1]["flags"].LOOPBACK
assert ifaces[1]["ips"][0]["address"] == "127.0.0.1"
assert ifaces[2]["name"] == "eth0"
assert ifaces[2]["mac"] == "de:ad:be:ef:ca:fe"
assert ifaces[2]["type"] == 1
assert ifaces[2]["flags"].MULTICAST
assert ifaces[2]["ips"][0]["address"] == "192.168.1.2"


############
############

+ RTNetlink read_routes (IPv4)

= read_routes returns IPv4 routes with gateway and source address
~ mock

from scapy.arch.linux.rtnetlink import (
    rtmsghdr, ifinfomsg, ifinfomsg_rtattr, ifaddrmsg, ifaddrmsg_rtattr,
    rtmsg, rtmsg_rtattr, nlmsgerr, read_routes
)
from unittest import mock
import socket

done = rtmsghdr(
    nlmsg_type="NLMSG_DONE", nlmsg_flags=0, nlmsg_seq=1, nlmsg_pid=100,
) / nlmsgerr(status=0, data=[])

eth0 = rtmsghdr(
    nlmsg_type="RTM_NEWLINK", nlmsg_flags="NLM_F_MULTI", nlmsg_seq=1, nlmsg_pid=100,
) / ifinfomsg(
    ifi_family=0, ifi_type=1, ifi_index=2,
    ifi_flags="UP+BROADCAST+RUNNING+MULTICAST",
    data=[
        ifinfomsg_rtattr(rta_type="IFLA_ADDRESS", rta_data="de:ad:be:ef:ca:fe"),
        ifinfomsg_rtattr(rta_type="IFLA_IFNAME", rta_data=b"eth0\x00"),
    ],
)
link_data = bytes(eth0) + bytes(done)

eth0_addr = rtmsghdr(
    nlmsg_type="RTM_NEWADDR", nlmsg_flags="NLM_F_MULTI", nlmsg_seq=1, nlmsg_pid=100,
) / ifaddrmsg(
    ifa_family=socket.AF_INET, ifa_prefixlen=24, ifa_flags=0x80, ifa_scope=0, ifa_index=2,
    data=[
        ifaddrmsg_rtattr(rta_type="IFA_ADDRESS", rta_data="192.168.1.2"),
        ifaddrmsg_rtattr(rta_type="IFA_LOCAL", rta_data="192.168.1.2"),
    ],
)
addr_data = bytes(eth0_addr) + bytes(done)

subnet_route = rtmsghdr(
    nlmsg_type="RTM_NEWROUTE", nlmsg_flags="NLM_F_MULTI", nlmsg_seq=1, nlmsg_pid=100,
) / rtmsg(
    rtm_family=socket.AF_INET, rtm_dst_len=24, rtm_table="RT_TABLE_MAIN",
    rtm_protocol="RTPROT_KERNEL", rtm_scope="RT_SCOPE_LINK", rtm_type="RTN_UNICAST",
    data=[
        rtmsg_rtattr(rta_type="RTA_DST", rta_data="192.168.1.0"),
        rtmsg_rtattr(rta_type="RTS_OIF", rta_data=2),
        rtmsg_rtattr(rta_type="RTA_PREFSRC", rta_data="192.168.1.2"),
        rtmsg_rtattr(rta_type="RTA_TABLE", rta_data="RT_TABLE_MAIN"),
    ],
)
default_route = rtmsghdr(
    nlmsg_type="RTM_NEWROUTE", nlmsg_flags="NLM_F_MULTI", nlmsg_seq=1, nlmsg_pid=100,
) / rtmsg(
    rtm_family=socket.AF_INET, rtm_dst_len=0, rtm_table="RT_TABLE_MAIN",
    rtm_protocol="RTPROT_BOOT", rtm_scope="RT_SCOPE_UNIVERSE", rtm_type="RTN_UNICAST",
    data=[
        rtmsg_rtattr(rta_type="RTA_GATEWAY", rta_data="192.168.1.1"),
        rtmsg_rtattr(rta_type="RTS_OIF", rta_data=2),
        rtmsg_rtattr(rta_type="RTA_PREFSRC", rta_data="192.168.1.2"),
        rtmsg_rtattr(rta_type="RTA_TABLE", rta_data="RT_TABLE_MAIN"),
    ],
)
# Local table has no routes in this test
local_route_data = bytes(done)
main_route_data = bytes(subnet_route) + bytes(default_route) + bytes(done)

# read_routes calls:
#   _get_if_list(): socket1=link_data, socket2=addr_data
#   _read_routes(): socket3=local_route_data (RT_TABLE_LOCAL), socket4=main_route_data (RT_TABLE_MAIN)
_socket_responses = iter([link_data, addr_data, local_route_data, main_route_data])
def _mock_socket(*args, **kwargs):
    data = next(_socket_responses)
    s = mock.MagicMock()
    s.recv.return_value = data
    return s

with mock.patch("socket.socket", side_effect=_mock_socket):
    routes = read_routes()

from scapy.utils import atol, itom
# Find the subnet route (192.168.1.0/24)
subnet = next(r for r in routes if r[0] == atol("192.168.1.0"))
assert subnet[1] == itom(24)       # mask
assert subnet[2] == "0.0.0.0"     # no gateway for directly connected
assert subnet[3] == "eth0"         # interface
assert subnet[4] == "192.168.1.2"  # source address

# Find the default route (0.0.0.0/0)
default = next(r for r in routes if r[0] == 0 and r[1] == 0)
assert default[2] == "192.168.1.1"  # gateway
assert default[3] == "eth0"

= read_routes includes multicast route for MULTICAST interfaces
~ mock

from scapy.arch.linux.rtnetlink import (
    rtmsghdr, ifinfomsg, ifinfomsg_rtattr, ifaddrmsg, ifaddrmsg_rtattr,
    rtmsg, rtmsg_rtattr, nlmsgerr, read_routes
)
from unittest import mock
import socket

done = rtmsghdr(
    nlmsg_type="NLMSG_DONE", nlmsg_flags=0, nlmsg_seq=1, nlmsg_pid=100,
) / nlmsgerr(status=0, data=[])

eth0 = rtmsghdr(
    nlmsg_type="RTM_NEWLINK", nlmsg_flags="NLM_F_MULTI", nlmsg_seq=1, nlmsg_pid=100,
) / ifinfomsg(
    ifi_family=0, ifi_type=1, ifi_index=2,
    ifi_flags="UP+BROADCAST+RUNNING+MULTICAST",
    data=[
        ifinfomsg_rtattr(rta_type="IFLA_ADDRESS", rta_data="de:ad:be:ef:ca:fe"),
        ifinfomsg_rtattr(rta_type="IFLA_IFNAME", rta_data=b"eth0\x00"),
    ],
)
eth0_addr = rtmsghdr(
    nlmsg_type="RTM_NEWADDR", nlmsg_flags="NLM_F_MULTI", nlmsg_seq=1, nlmsg_pid=100,
) / ifaddrmsg(
    ifa_family=socket.AF_INET, ifa_prefixlen=24, ifa_flags=0x80, ifa_scope=0, ifa_index=2,
    data=[
        ifaddrmsg_rtattr(rta_type="IFA_ADDRESS", rta_data="192.168.1.2"),
        ifaddrmsg_rtattr(rta_type="IFA_LOCAL", rta_data="192.168.1.2"),
    ],
)

_socket_responses = iter([
    bytes(eth0) + bytes(done),   # link
    bytes(eth0_addr) + bytes(done),   # addr
    bytes(done),   # local routes (empty)
    bytes(done),   # main routes (empty)
])
def _mock_socket(*args, **kwargs):
    data = next(_socket_responses)
    s = mock.MagicMock()
    s.recv.return_value = data
    return s

with mock.patch("socket.socket", side_effect=_mock_socket):
    routes = read_routes()

# A multicast route should be added for eth0 (224.0.0.0/4)
mcast = next((r for r in routes if r[0] == 0xe0000000), None)
assert mcast is not None
assert mcast[1] == 0xf0000000   # /4 mask
assert mcast[2] == "0.0.0.0"
assert mcast[3] == "eth0"
assert mcast[4] == "192.168.1.2"
assert mcast[5] == 250           # metric

