    nlmsg_type="NLMSG_DONE", nlmsg_flags=0, nlmsg_seq=1, nlmsg_pid=100,
) / nlmsgerr(
    status=1,
    data=[nlmsgerr_rtattr(rta_type=1, rta_data=b"RTNetlink error")],
