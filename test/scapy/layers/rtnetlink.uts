+ RTNetlink read_routes6 (IPv6)

= read_routes6 returns IPv6 routes with source candidates
~ mock

from scapy.arch.linux.rtnetlink import (
    rtmsghdr, ifinfomsg, ifinfomsg_rtattr, ifaddrmsg, ifaddrmsg_rtattr,
    rtmsg, rtmsg_rtattr, nlmsgerr, read_routes6
)
from unittest import mock
import socket

done = rtmsghdr(
    nlmsg_type="NLMSG_DONE", nlmsg_flags=0, nlmsg_seq=1, nlmsg_pid=100,
) / nlmsgerr(status=0, data=[])

eth0 = rtmsghdr(
    nlmsg_type="RTM_NEWLINK", nlmsg_flags="NLM_F_MULTI", nlmsg_seq=1, nlmsg_pid=100,
) / ifinfomsg(
    ifi_family=0, ifi_type=1, ifi_index=2,
    ifi_flags="UP+BROADCAST+RUNNING+MULTICAST",
    data=[
        ifinfomsg_rtattr(rta_type="IFLA_ADDRESS", rta_data="de:ad:be:ef:ca:fe"),
        ifinfomsg_rtattr(rta_type="IFLA_IFNAME", rta_data=b"eth0\x00"),
    ],
)
addr_v4 = rtmsghdr(
    nlmsg_type="RTM_NEWADDR", nlmsg_flags="NLM_F_MULTI", nlmsg_seq=1, nlmsg_pid=100,
) / ifaddrmsg(
    ifa_family=socket.AF_INET, ifa_prefixlen=24, ifa_flags=0x80, ifa_scope=0, ifa_index=2,
    data=[
        ifaddrmsg_rtattr(rta_type="IFA_ADDRESS", rta_data="192.168.1.2"),
        ifaddrmsg_rtattr(rta_type="IFA_LOCAL", rta_data="192.168.1.2"),
    ],
)
addr_v6 = rtmsghdr(
    nlmsg_type="RTM_NEWADDR", nlmsg_flags="NLM_F_MULTI", nlmsg_seq=1, nlmsg_pid=100,
) / ifaddrmsg(
    ifa_family=socket.AF_INET6, ifa_prefixlen=64, ifa_flags=0x80, ifa_scope=0, ifa_index=2,
    data=[
        ifaddrmsg_rtattr(rta_type="IFA_ADDRESS", rta_data="2001:db8::1"),
        ifaddrmsg_rtattr(rta_type="IFA_LOCAL", rta_data="2001:db8::1"),
    ],
)
route_v6 = rtmsghdr(
    nlmsg_type="RTM_NEWROUTE", nlmsg_flags="NLM_F_MULTI", nlmsg_seq=1, nlmsg_pid=100,
) / rtmsg(
    rtm_family=socket.AF_INET6, rtm_dst_len=64, rtm_table="RT_TABLE_MAIN",
    rtm_protocol="RTPROT_KERNEL", rtm_scope="RT_SCOPE_LINK", rtm_type="RTN_UNICAST",
    data=[
        rtmsg_rtattr(rta_type="RTA_DST", rta_data="2001:db8::"),
        rtmsg_rtattr(rta_type="RTS_OIF", rta_data=2),
        rtmsg_rtattr(rta_type="RTA_TABLE", rta_data="RT_TABLE_MAIN"),
    ],
)

link_data = bytes(eth0) + bytes(done)
# addr response (all families) used by _get_if_list -> _get_ips
addr_all_data = bytes(addr_v4) + bytes(addr_v6) + bytes(done)
# addr response (IPv6 only) used by read_routes6 -> _get_ips(AF_INET6)
addr_v6_only_data = bytes(addr_v6) + bytes(done)

# read_routes6 calls:
#   _get_if_list(): socket1=link_data, socket2=addr_all_data
#   _read_routes(AF_INET6): socket3=empty (LOCAL), socket4=route_v6 (MAIN)
#   _get_ips(AF_INET6): socket5=addr_v6_only_data
_socket_responses = iter([
    link_data, addr_all_data,
    bytes(done), bytes(route_v6) + bytes(done),
    addr_v6_only_data,
])
def _mock_socket(*args, **kwargs):
    data = next(_socket_responses)
    s = mock.MagicMock()
    s.recv.return_value = data
    return s

with mock.patch("socket.socket", side_effect=_mock_socket):
    routes = read_routes6()

# Should have the 2001:db8::/64 route
subnet = next(r for r in routes if r[0] == "2001:db8::" and r[1] == 64)
assert subnet[2] == "::"        # no gateway (link-local)
assert subnet[3] == "eth0"
assert "2001:db8::1" in subnet[4]  # source candidates
assert subnet[5] == 0           # metric

= read_routes6 includes multicast route for MULTICAST interfaces with IPv6 addresses
~ mock

from scapy.arch.linux.rtnetlink import (
    rtmsghdr, ifinfomsg, ifinfomsg_rtattr, ifaddrmsg, ifaddrmsg_rtattr,
    nlmsgerr, read_routes6
)
from unittest import mock
import socket

done = rtmsghdr(
    nlmsg_type="NLMSG_DONE", nlmsg_flags=0, nlmsg_seq=1, nlmsg_pid=100,
) / nlmsgerr(status=0, data=[])

eth0 = rtmsghdr(
    nlmsg_type="RTM_NEWLINK", nlmsg_flags="NLM_F_MULTI", nlmsg_seq=1, nlmsg_pid=100,
) / ifinfomsg(
    ifi_family=0, ifi_type=1, ifi_index=2,
    ifi_flags="UP+BROADCAST+RUNNING+MULTICAST",
    data=[
        ifinfomsg_rtattr(rta_type="IFLA_ADDRESS", rta_data="de:ad:be:ef:ca:fe"),
        ifinfomsg_rtattr(rta_type="IFLA_IFNAME", rta_data=b"eth0\x00"),
    ],
)
addr_v6 = rtmsghdr(
    nlmsg_type="RTM_NEWADDR", nlmsg_flags="NLM_F_MULTI", nlmsg_seq=1, nlmsg_pid=100,
) / ifaddrmsg(
    ifa_family=socket.AF_INET6, ifa_prefixlen=64, ifa_flags=0x80, ifa_scope=0, ifa_index=2,
    data=[
        ifaddrmsg_rtattr(rta_type="IFA_ADDRESS", rta_data="2001:db8::1"),
        ifaddrmsg_rtattr(rta_type="IFA_LOCAL", rta_data="2001:db8::1"),
    ],
)

_socket_responses = iter([
    bytes(eth0) + bytes(done),
    bytes(addr_v6) + bytes(done),   # addr_all for _get_if_list -> _get_ips
    bytes(done),                    # local routes
    bytes(done),                    # main routes
    bytes(addr_v6) + bytes(done),   # IPv6 addr for read_routes6
])
def _mock_socket(*args, **kwargs):
    data = next(_socket_responses)
    s = mock.MagicMock()
    s.recv.return_value = data
    return s

with mock.patch("socket.socket", side_effect=_mock_socket):
    routes = read_routes6()

# Multicast route ff00::/8 should be added for MULTICAST eth0
mcast = next((r for r in routes if r[0] == "ff00::"), None)
assert mcast is not None
assert mcast[1] == 8
assert mcast[2] == "::"
assert mcast[3] == "eth0"
assert "2001:db8::1" in mcast[4]
assert mcast[5] == 250


