% Unit tests for the RTNetlink component
~ mock

# More information at http://www.secdev.org/projects/UTscapy/


############
############

+ RTNetlink Packet Construction and Dissection

= rtmsghdr auto-length calculation
~ mock

from scapy.arch.linux.rtnetlink import rtmsghdr, ifinfomsg

pkt = rtmsghdr(
    nlmsg_type="RTM_GETLINK",
    nlmsg_flags="NLM_F_REQUEST+NLM_F_ROOT+NLM_F_MATCH",
) / ifinfomsg(data=[])
raw = bytes(pkt)
parsed = rtmsghdr(raw)
assert parsed.nlmsg_len == len(raw)
assert parsed.nlmsg_type == 18  # RTM_GETLINK

= rtmsghdr RTM_NEWLINK dissection
~ mock

from scapy.arch.linux.rtnetlink import rtmsghdr, ifinfomsg, ifinfomsg_rtattr

newlink_raw = bytes.fromhex(
    "38000000100002000100000064000000"
    "000001000200000043100000000000000a000100deadbeefcafe000009000300"
    "6574683000000000"
)
pkt = rtmsghdr(newlink_raw)
assert pkt.nlmsg_type == 16  # RTM_NEWLINK
assert pkt.nlmsg_flags.NLM_F_MULTI
assert pkt.nlmsg_len == 56
assert pkt.ifi_index == 2
assert pkt.ifi_type == 1  # ARPHRD_ETHER
assert pkt.ifi_flags.UP
assert pkt.ifi_flags.BROADCAST
assert pkt.ifi_flags.RUNNING
assert pkt.ifi_flags.MULTICAST
assert len(pkt.data) == 2
assert pkt.data[0].rta_type == 1   # IFLA_ADDRESS
assert pkt.data[0].rta_data == "de:ad:be:ef:ca:fe"
assert pkt.data[1].rta_type == 3   # IFLA_IFNAME
assert pkt.data[1].rta_data == b"eth0\x00"

= rtmsghdr RTM_NEWADDR IPv4 dissection
~ mock

from scapy.arch.linux.rtnetlink import rtmsghdr, ifaddrmsg, ifaddrmsg_rtattr
import socket

newaddr_raw = bytes.fromhex(
    "34000000140002000100000064000000"
    "021880000200000008000100c0a8010208000200c0a80102090003006574683000000000"
)
pkt = rtmsghdr(newaddr_raw)
assert pkt.nlmsg_type == 20  # RTM_NEWADDR
assert pkt.ifa_family == socket.AF_INET
assert pkt.ifa_prefixlen == 24
assert pkt.ifa_index == 2
assert len(pkt.data) == 3
ifa_addr = next(a for a in pkt.data if a.rta_type == 0x01)  # IFA_ADDRESS
ifa_local = next(a for a in pkt.data if a.rta_type == 0x02)  # IFA_LOCAL
ifa_label = next(a for a in pkt.data if a.rta_type == 0x03)  # IFA_LABEL
assert ifa_addr.rta_data == "192.168.1.2"
assert ifa_local.rta_data == "192.168.1.2"
assert ifa_label.rta_data == b"eth0\x00"

= rtmsghdr RTM_NEWADDR IPv6 dissection
~ mock

from scapy.arch.linux.rtnetlink import rtmsghdr, ifaddrmsg, ifaddrmsg_rtattr
import socket

newaddr_v6_raw = bytes.fromhex(
    "400000001400020001000000640000000a408000020000001400010020010db800000000"
    "000000000000000114000200" "20010db8000000000000000000000001"
)
pkt = rtmsghdr(newaddr_v6_raw)
assert pkt.nlmsg_type == 20  # RTM_NEWADDR
assert pkt.ifa_family == socket.AF_INET6
assert pkt.ifa_prefixlen == 64
assert pkt.ifa_index == 2
ifa_addr = next(a for a in pkt.data if a.rta_type == 0x01)  # IFA_ADDRESS
assert ifa_addr.rta_data == "2001:db8::1"

= rtmsghdr RTM_NEWROUTE IPv4 dissection
~ mock

from scapy.arch.linux.rtnetlink import rtmsghdr, rtmsg, rtmsg_rtattr
import socket

newroute_raw = bytes.fromhex(
    "3c00000018000200010000006400000002180000fe02fd01000000000800010"
    "0c0a80100080004000200000008000700c0a8010208000f00fe000000"
)
pkt = rtmsghdr(newroute_raw)
assert pkt.nlmsg_type == 24  # RTM_NEWROUTE
assert pkt.rtm_family == socket.AF_INET
assert pkt.rtm_dst_len == 24
rta_dst = next(a for a in pkt.data if a.rta_type == 0x01)   # RTA_DST
rta_oif = next(a for a in pkt.data if a.rta_type == 0x04)   # RTS_OIF
rta_src = next(a for a in pkt.data if a.rta_type == 0x07)   # RTA_PREFSRC
assert rta_dst.rta_data == "192.168.1.0"
assert rta_oif.rta_data == 2
assert rta_src.rta_data == "192.168.1.2"

= NLMSG_DONE packet construction and dissection
~ mock

from scapy.arch.linux.rtnetlink import rtmsghdr, nlmsgerr

done_pkt = rtmsghdr(
    nlmsg_type="NLMSG_DONE", nlmsg_flags=0, nlmsg_seq=1, nlmsg_pid=100,
) / nlmsgerr(status=0, data=[])
raw = bytes(done_pkt)
parsed = rtmsghdr(raw)
assert parsed.nlmsg_type == 3   # NLMSG_DONE
assert not parsed.nlmsg_flags.NLM_F_MULTI
assert parsed.status == 0

= rtmsghdrs multi-message parsing
~ mock

from scapy.arch.linux.rtnetlink import (
    rtmsghdr, ifinfomsg, ifinfomsg_rtattr, nlmsgerr, rtmsghdrs
)

link1 = rtmsghdr(
    nlmsg_type="RTM_NEWLINK", nlmsg_flags="NLM_F_MULTI", nlmsg_seq=1, nlmsg_pid=100,
) / ifinfomsg(
    ifi_family=0, ifi_type=1, ifi_index=2,
    ifi_flags="UP+BROADCAST+RUNNING+MULTICAST",
    data=[
        ifinfomsg_rtattr(rta_type="IFLA_ADDRESS", rta_data="de:ad:be:ef:ca:fe"),
        ifinfomsg_rtattr(rta_type="IFLA_IFNAME", rta_data=b"eth0\x00"),
    ],
)
done = rtmsghdr(
    nlmsg_type="NLMSG_DONE", nlmsg_flags=0, nlmsg_seq=1, nlmsg_pid=100,
) / nlmsgerr(status=0, data=[])

combined = bytes(link1) + bytes(done)
parsed = rtmsghdrs(combined)
assert len(parsed.msgs) == 2
assert parsed.msgs[0].nlmsg_type == 16   # RTM_NEWLINK
assert parsed.msgs[1].nlmsg_type == 3    # NLMSG_DONE


############
############

+ RTNetlink Socket Emulation Helpers

= _sr1_rtrequest returns results for multi-message response
~ mock

from scapy.arch.linux.rtnetlink import (
    rtmsghdr, ifinfomsg, ifinfomsg_rtattr, nlmsgerr, _sr1_rtrequest
)
from unittest import mock

newlink = rtmsghdr(
    nlmsg_type="RTM_NEWLINK", nlmsg_flags="NLM_F_MULTI", nlmsg_seq=1, nlmsg_pid=100,
) / ifinfomsg(
    ifi_family=0, ifi_type=1, ifi_index=2,
    ifi_flags="UP+BROADCAST+RUNNING+MULTICAST",
    data=[
        ifinfomsg_rtattr(rta_type="IFLA_ADDRESS", rta_data="de:ad:be:ef:ca:fe"),
        ifinfomsg_rtattr(rta_type="IFLA_IFNAME", rta_data=b"eth0\x00"),
    ],
)
done = rtmsghdr(
    nlmsg_type="NLMSG_DONE", nlmsg_flags=0, nlmsg_seq=1, nlmsg_pid=100,
) / nlmsgerr(status=0, data=[])

response_data = bytes(newlink) + bytes(done)
mock_sock = mock.MagicMock()
mock_sock.recv.return_value = response_data
req = rtmsghdr(
    nlmsg_type="RTM_GETLINK", nlmsg_flags="NLM_F_REQUEST+NLM_F_ROOT+NLM_F_MATCH",
    nlmsg_seq=1,
) / ifinfomsg(data=[])
with mock.patch("socket.socket", return_value=mock_sock):
    results = _sr1_rtrequest(req)
    assert len(results) == 1
    assert results[0].nlmsg_type == 16   # RTM_NEWLINK
    assert results[0].ifi_index == 2

= _sr1_rtrequest returns empty list on NLMSG_DONE with error
~ mock

from scapy.arch.linux.rtnetlink import (
    rtmsghdr, ifaddrmsg, nlmsgerr, nlmsgerr_rtattr, _sr1_rtrequest
)
from unittest import mock
import socket

done_err = rtmsghdr(
    nlmsg_type="NLMSG_DONE", nlmsg_flags=0, nlmsg_seq=1, nlmsg_pid=100,
) / nlmsgerr(
    status=1,
    data=[nlmsgerr_rtattr(rta_type=1, rta_data=b"RTNetlink error")],
)
mock_sock = mock.MagicMock()
mock_sock.recv.return_value = bytes(done_err)
req = rtmsghdr(
    nlmsg_type="RTM_GETADDR", nlmsg_flags="NLM_F_REQUEST", nlmsg_seq=1,
) / ifaddrmsg(ifa_family=socket.AF_UNSPEC, data=[])
with mock.patch("socket.socket", return_value=mock_sock):
    results = _sr1_rtrequest(req)
    assert results == []

= _sr1_rtrequest stops at non-MULTI message
~ mock

from scapy.arch.linux.rtnetlink import (
    rtmsghdr, ifinfomsg, ifinfomsg_rtattr, nlmsgerr, _sr1_rtrequest
)
from unittest import mock

# A response without NLM_F_MULTI set terminates immediately
single = rtmsghdr(
    nlmsg_type="RTM_NEWLINK", nlmsg_flags=0, nlmsg_seq=1, nlmsg_pid=100,
) / ifinfomsg(
    ifi_family=0, ifi_type=1, ifi_index=2,
    ifi_flags="UP+BROADCAST+RUNNING+MULTICAST",
    data=[
        ifinfomsg_rtattr(rta_type="IFLA_ADDRESS", rta_data="de:ad:be:ef:ca:fe"),
        ifinfomsg_rtattr(rta_type="IFLA_IFNAME", rta_data=b"eth0\x00"),
    ],
)
mock_sock = mock.MagicMock()
mock_sock.recv.return_value = bytes(single)
req = rtmsghdr(
    nlmsg_type="RTM_GETLINK", nlmsg_flags="NLM_F_REQUEST", nlmsg_seq=1,
) / ifinfomsg(data=[])
with mock.patch("socket.socket", return_value=mock_sock):
    results = _sr1_rtrequest(req)
    # The non-MULTI message terminates immediately without being appended
    assert results == []


############
