from scapy.arch.linux.rtnetlink import (
    rtmsghdr, ifinfomsg, ifinfomsg_rtattr, ifaddrmsg, ifaddrmsg_rtattr,
    rtmsg, rtmsg_rtattr, nlmsgerr, read_routes
)
from unittest import mock
import socket

done = rtmsghdr(
    nlmsg_type="NLMSG_DONE", nlmsg_flags=0, nlmsg_pid=100,
) / nlmsgerr(status=0, data=[])

eth0 = rtmsghdr(
    nlmsg_type="RTM_NEWLINK", nlmsg_flags="NLM_F_MULTI", nlmsg_pid=100,
) / ifinfomsg(
    ifi_family=0, ifi_type=1, ifi_index=5,
    ifi_flags="UP+BROADCAST+RUNNING+MULTICAST",
    data=[
        ifinfomsg_rtattr(rta_type="IFLA_ADDRESS", rta_data="aa:bb:cc:dd:ee:ff"),
        ifinfomsg_rtattr(rta_type="IFLA_IFNAME", rta_data=b"enp3s0\x00"),
    ],
)
eth0_addr = rtmsghdr(
    nlmsg_type="RTM_NEWADDR", nlmsg_flags="NLM_F_MULTI", nlmsg_pid=100,
) / ifaddrmsg(
    ifa_family=socket.AF_INET, ifa_prefixlen=24, ifa_flags=0x80, ifa_scope=0, ifa_index=5,
    data=[
        ifaddrmsg_rtattr(rta_type="IFA_ADDRESS", rta_data="10.0.0.5"),
        ifaddrmsg_rtattr(rta_type="IFA_LOCAL", rta_data="10.0.0.5"),
    ],
)
route = rtmsghdr(
    nlmsg_type="RTM_NEWROUTE", nlmsg_flags="NLM_F_MULTI", nlmsg_pid=100,
) / rtmsg(
    rtm_family=socket.AF_INET, rtm_dst_len=24, rtm_table="RT_TABLE_MAIN",
    rtm_protocol="RTPROT_KERNEL", rtm_scope="RT_SCOPE_LINK", rtm_type="RTN_UNICAST",
    data=[
        rtmsg_rtattr(rta_type="RTA_DST", rta_data="10.0.0.0"),
        rtmsg_rtattr(rta_type="RTS_OIF", rta_data=5),
        rtmsg_rtattr(rta_type="RTA_PREFSRC", rta_data="10.0.0.5"),
    ],
)

_socket_responses = iter([
    bytes(eth0) + bytes(done),
    bytes(eth0_addr) + bytes(done),
    bytes(done),
    bytes(route) + bytes(done),
])
def _mock_socket(*args, **kwargs):
    data = next(_socket_responses)
    s = mock.MagicMock()
    s.recv.return_value = data
    return s

with mock.patch("socket.socket", side_effect=_mock_socket):
    routes = read_routes()

from scapy.utils import atol, itom
r = next(rt for rt in routes if rt[0] == atol("10.0.0.0"))
assert r[3] == "enp3s0"


