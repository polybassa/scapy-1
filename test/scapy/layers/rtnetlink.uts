+ RTNetlink _get_ips

= _get_ips returns IPv4 addresses indexed by interface
~ mock

from scapy.arch.linux.rtnetlink import (
    rtmsghdr, ifaddrmsg, ifaddrmsg_rtattr, nlmsgerr, _get_ips
)
from unittest import mock
import socket

lo_addr = rtmsghdr(
    nlmsg_type="RTM_NEWADDR", nlmsg_flags="NLM_F_MULTI", nlmsg_seq=1, nlmsg_pid=100,
) / ifaddrmsg(
    ifa_family=socket.AF_INET, ifa_prefixlen=8, ifa_flags=0x80, ifa_scope=254, ifa_index=1,
    data=[
        ifaddrmsg_rtattr(rta_type="IFA_ADDRESS", rta_data="127.0.0.1"),
        ifaddrmsg_rtattr(rta_type="IFA_LOCAL", rta_data="127.0.0.1"),
    ],
)
eth0_addr = rtmsghdr(
    nlmsg_type="RTM_NEWADDR", nlmsg_flags="NLM_F_MULTI", nlmsg_seq=1, nlmsg_pid=100,
) / ifaddrmsg(
    ifa_family=socket.AF_INET, ifa_prefixlen=24, ifa_flags=0x80, ifa_scope=0, ifa_index=2,
    data=[
        ifaddrmsg_rtattr(rta_type="IFA_ADDRESS", rta_data="192.168.1.2"),
        ifaddrmsg_rtattr(rta_type="IFA_LOCAL", rta_data="192.168.1.2"),
        ifaddrmsg_rtattr(rta_type="IFA_LABEL", rta_data=b"eth0\x00"),
    ],
)
done = rtmsghdr(
    nlmsg_type="NLMSG_DONE", nlmsg_flags=0, nlmsg_seq=1, nlmsg_pid=100,
) / nlmsgerr(status=0, data=[])

response_data = bytes(lo_addr) + bytes(eth0_addr) + bytes(done)
mock_sock = mock.MagicMock()
mock_sock.recv.return_value = response_data
with mock.patch("socket.socket", return_value=mock_sock):
    ips = _get_ips()

assert 1 in ips
assert 2 in ips
assert ips[1][0]["address"] == "127.0.0.1"
assert ips[1][0]["af_family"] == socket.AF_INET
assert ips[1][0]["index"] == 1
assert ips[2][0]["address"] == "192.168.1.2"
assert ips[2][0]["af_family"] == socket.AF_INET
assert ips[2][0]["index"] == 2

= _get_ips uses IFA_LOCAL over IFA_ADDRESS for point-to-point interfaces
~ mock

from scapy.arch.linux.rtnetlink import (
    rtmsghdr, ifaddrmsg, ifaddrmsg_rtattr, nlmsgerr, _get_ips
)
from unittest import mock
import socket

# For point-to-point: IFA_ADDRESS is the peer, IFA_LOCAL is the local address
ptp = rtmsghdr(
    nlmsg_type="RTM_NEWADDR", nlmsg_flags="NLM_F_MULTI", nlmsg_seq=1, nlmsg_pid=100,
) / ifaddrmsg(
    ifa_family=socket.AF_INET, ifa_prefixlen=32, ifa_flags=0x80, ifa_scope=0, ifa_index=3,
    data=[
        ifaddrmsg_rtattr(rta_type="IFA_ADDRESS", rta_data="10.0.0.2"),   # peer address
        ifaddrmsg_rtattr(rta_type="IFA_LOCAL", rta_data="10.0.0.1"),     # local address
    ],
)
done = rtmsghdr(
    nlmsg_type="NLMSG_DONE", nlmsg_flags=0, nlmsg_seq=1, nlmsg_pid=100,
) / nlmsgerr(status=0, data=[])

mock_sock = mock.MagicMock()
mock_sock.recv.return_value = bytes(ptp) + bytes(done)
with mock.patch("socket.socket", return_value=mock_sock):
    ips = _get_ips()

assert 3 in ips
# IFA_LOCAL (local address) must be used, not IFA_ADDRESS (peer)
assert ips[3][0]["address"] == "10.0.0.1"

= _get_ips returns IPv6 addresses with scope
~ mock

from scapy.arch.linux.rtnetlink import (
    rtmsghdr, ifaddrmsg, ifaddrmsg_rtattr, nlmsgerr, _get_ips
)
from unittest import mock
import socket

eth0_v6 = rtmsghdr(
    nlmsg_type="RTM_NEWADDR", nlmsg_flags="NLM_F_MULTI", nlmsg_seq=1, nlmsg_pid=100,
) / ifaddrmsg(
    ifa_family=socket.AF_INET6, ifa_prefixlen=64, ifa_flags=0x80, ifa_scope=0, ifa_index=2,
    data=[
        ifaddrmsg_rtattr(rta_type="IFA_ADDRESS", rta_data="2001:db8::1"),
        ifaddrmsg_rtattr(rta_type="IFA_LOCAL", rta_data="2001:db8::1"),
    ],
)
done = rtmsghdr(
    nlmsg_type="NLMSG_DONE", nlmsg_flags=0, nlmsg_seq=1, nlmsg_pid=100,
) / nlmsgerr(status=0, data=[])

mock_sock = mock.MagicMock()
mock_sock.recv.return_value = bytes(eth0_v6) + bytes(done)
with mock.patch("socket.socket", return_value=mock_sock):
    ips = _get_ips(af_family=socket.AF_INET6)

assert 2 in ips
assert ips[2][0]["address"] == "2001:db8::1"
assert ips[2][0]["af_family"] == socket.AF_INET6
assert "scope" in ips[2][0]

= _get_ips returns empty dict on error
~ mock

from scapy.arch.linux.rtnetlink import (
    rtmsghdr, nlmsgerr, nlmsgerr_rtattr, _get_ips
